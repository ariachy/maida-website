# DO NOT REMOVE. CLOUDLINUX PASSENGER CONFIGURATION BEGIN
PassengerAppRoot "/home/thehlxvx/maida.pt"
PassengerBaseURI "/"
PassengerNodejs "/home/thehlxvx/nodevenv/maida.pt/20/bin/node"
PassengerAppType node
PassengerStartupFile server.js
# DO NOT REMOVE. CLOUDLINUX PASSENGER CONFIGURATION END

# ===========================================
# Maída Website - Optimized .htaccess
# Performance + Security + SEO
# ===========================================

# Enable rewrite engine
RewriteEngine On

# ===========================================
# HTTPS & WWW REDIRECTS
# ===========================================

# Redirect HTTP to HTTPS
RewriteCond %{HTTPS} off
RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# Redirect www to non-www (optional - uncomment if needed)
# RewriteCond %{HTTP_HOST} ^www\.(.*)$ [NC]
# RewriteRule ^(.*)$ https://%1/$1 [R=301,L]

# ===========================================
# CLEAN URLs — DISABLED (Node.js/Passenger handles all routing)
# These were for static export mode. With a running Node server,
# they intercept routes like /api/*, /review, /admin before
# Passenger can forward them to Node.js.
# ===========================================

# Remove trailing slash (except for directories)
# RewriteCond %{REQUEST_FILENAME} !-d
# RewriteRule ^(.*)/$ /$1 [L,R=301]

# Handle clean URLs for Next.js static export
# RewriteCond %{REQUEST_FILENAME} !-f
# RewriteCond %{REQUEST_FILENAME} !-d
# RewriteCond %{REQUEST_FILENAME}.html -f
# RewriteRule ^(.*)$ $1.html [L]

# Custom 404 — handled by Next.js
# ErrorDocument 404 /404.html

# ===========================================
# SECURITY HEADERS
# ===========================================

<IfModule mod_headers.c>
    # -------------------------------------------
    # HSTS (HTTP Strict Transport Security)
    # -------------------------------------------
    Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"

    # -------------------------------------------
    # COOP (Cross-Origin-Opener-Policy)
    # -------------------------------------------
    Header always set Cross-Origin-Opener-Policy "same-origin-allow-popups"

    # -------------------------------------------
    # CSP (Content Security Policy)
    # -------------------------------------------
    Header always set Content-Security-Policy "\
        default-src 'self'; \
        script-src 'self' 'unsafe-inline' 'unsafe-eval' \
            https://www.googletagmanager.com \
            https://www.google-analytics.com \
            https://googleads.g.doubleclick.net \
            https://www.google.com \
            https://www.gstatic.com \
            https://maps.googleapis.com \
            https://maps.gstatic.com \
            https://widget.letsumai.com \
            https://js.stripe.com \
            https://www.google.com/recaptcha/ \
            https://www.gstatic.com/recaptcha/; \
        style-src 'self' 'unsafe-inline' \
            https://fonts.googleapis.com \
            https://widget.letsumai.com; \
        img-src 'self' data: blob: \
            https://www.google-analytics.com \
            https://www.googletagmanager.com \
            https://maps.googleapis.com \
            https://maps.gstatic.com \
            https://www.gstatic.com \
            https://*.google.com \
            https://*.googleapis.com \
            https://widget.letsumai.com \
            https://*.googleadservices.com; \
        font-src 'self' \
            https://fonts.gstatic.com; \
        connect-src 'self' \
            https://www.google-analytics.com \
            https://analytics.google.com \
            https://region1.google-analytics.com \
            https://www.googletagmanager.com \
            https://maps.googleapis.com \
            https://widget.letsumai.com \
            https://api.letsumai.com \
            https://letsumai.com \
            https://*.stripe.com \
            https://www.google.com; \
        frame-src 'self' \
            https://www.google.com \
            https://maps.google.com \
            https://www.google.com/maps/ \
            https://widget.letsumai.com \
            https://js.stripe.com \
            https://hooks.stripe.com \
            https://www.googletagmanager.com; \
        worker-src 'self' blob:; \
        frame-ancestors 'self'; \
        base-uri 'self'; \
        form-action 'self';"

    # -------------------------------------------
    # Other Security Headers
    # -------------------------------------------
    
    # Prevent MIME type sniffing
    Header set X-Content-Type-Options "nosniff"
    
    # Clickjacking protection
    Header set X-Frame-Options "SAMEORIGIN"
    
    # XSS Protection (legacy, CSP is primary protection now)
    Header set X-XSS-Protection "1; mode=block"
    
    # Referrer Policy
    Header set Referrer-Policy "strict-origin-when-cross-origin"
    
    # Permissions Policy
    Header set Permissions-Policy "camera=(), microphone=(), geolocation=(), payment=(self https://js.stripe.com)"
</IfModule>

# ===========================================
# CACHING - CRITICAL FOR PERFORMANCE
# ===========================================

<IfModule mod_expires.c>
    ExpiresActive On
    
    # Default
    ExpiresDefault "access plus 1 month"
    
    # HTML - short cache (content changes)
    ExpiresByType text/html "access plus 0 seconds"
    
    # CSS - 1 year (Next.js uses hashed filenames)
    ExpiresByType text/css "access plus 1 year"
    
    # JavaScript - 1 year (Next.js uses hashed filenames)
    ExpiresByType application/javascript "access plus 1 year"
    ExpiresByType text/javascript "access plus 1 year"
    
    # Images - 1 year
    ExpiresByType image/webp "access plus 1 year"
    ExpiresByType image/png "access plus 1 year"
    ExpiresByType image/jpg "access plus 1 year"
    ExpiresByType image/jpeg "access plus 1 year"
    ExpiresByType image/gif "access plus 1 year"
    ExpiresByType image/svg+xml "access plus 1 year"
    ExpiresByType image/x-icon "access plus 1 year"
    
    # Fonts - 1 year
    ExpiresByType font/woff "access plus 1 year"
    ExpiresByType font/woff2 "access plus 1 year"
    ExpiresByType application/font-woff "access plus 1 year"
    ExpiresByType application/font-woff2 "access plus 1 year"
    
    # JSON/XML - short cache
    ExpiresByType application/json "access plus 0 seconds"
    ExpiresByType application/xml "access plus 0 seconds"
</IfModule>

# ===========================================
# CACHE-CONTROL HEADERS (More specific control)
# ===========================================

<IfModule mod_headers.c>
    # Next.js static chunks - IMMUTABLE (hashed filenames)
    <FilesMatch "^.*\.(js|css)$">
        Header set Cache-Control "public, max-age=31536000, immutable"
    </FilesMatch>
    
    # Images - long cache
    <FilesMatch "\.(webp|png|jpg|jpeg|gif|svg|ico)$">
        Header set Cache-Control "public, max-age=31536000, immutable"
    </FilesMatch>
    
    # Fonts - long cache
    <FilesMatch "\.(woff|woff2|ttf|eot)$">
        Header set Cache-Control "public, max-age=31536000, immutable"
    </FilesMatch>
    
    # HTML - no cache (always fetch fresh)
    <FilesMatch "\.html$">
        Header set Cache-Control "no-cache, no-store, must-revalidate"
        Header set Pragma "no-cache"
        Header set Expires "0"
    </FilesMatch>
</IfModule>

# ===========================================
# SPECIFIC NEXT.JS _next/static CACHING
# ===========================================

<IfModule mod_headers.c>
    <If "%{REQUEST_URI} =~ m#^/_next/static/#">
        Header set Cache-Control "public, max-age=31536000, immutable"
    </If>
</IfModule>

# ===========================================
# COMPRESSION (GZIP/BROTLI)
# ===========================================

<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html
    AddOutputFilterByType DEFLATE text/plain
    AddOutputFilterByType DEFLATE text/xml
    AddOutputFilterByType DEFLATE text/css
    AddOutputFilterByType DEFLATE application/javascript
    AddOutputFilterByType DEFLATE application/json
    AddOutputFilterByType DEFLATE application/xml
    AddOutputFilterByType DEFLATE application/xhtml+xml
    AddOutputFilterByType DEFLATE application/rss+xml
    AddOutputFilterByType DEFLATE application/atom+xml
    AddOutputFilterByType DEFLATE image/svg+xml
    AddOutputFilterByType DEFLATE font/ttf
    AddOutputFilterByType DEFLATE font/otf
    AddOutputFilterByType DEFLATE application/vnd.ms-fontobject
    
    BrowserMatch ^Mozilla/4 gzip-only-text/html
    BrowserMatch ^Mozilla/4\.0[678] no-gzip
    BrowserMatch \bMSIE !no-gzip !gzip-only-text/html
    
    SetEnvIfNoCase Request_URI \.(?:gif|jpe?g|png|webp|zip|gz|bz2|rar)$ no-gzip
</IfModule>

# ===========================================
# ETAG CONFIGURATION
# ===========================================

<IfModule mod_headers.c>
    Header unset ETag
</IfModule>
FileETag None

# ===========================================
# PREVENT DIRECTORY LISTING
# ===========================================

Options -Indexes

# ===========================================
# BLOCK SENSITIVE FILES
# ===========================================

<FilesMatch "^\.">
    Order allow,deny
    Deny from all
</FilesMatch>

<FilesMatch "^\.env">
    Order allow,deny
    Deny from all
</FilesMatch>

<FilesMatch "rate_limits\.json$">
    Order allow,deny
    Deny from all
</FilesMatch>

<FilesMatch "\.(env|log|ini|bak|sql|sh|py)$">
    Order allow,deny
    Deny from all
</FilesMatch>